<Window x:Class="FotoCreaDB.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FotoCreaDB"
        Height="800"
        Width="1280"
        MinHeight="750"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource BrushBg}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="250"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="FotoCreaDB" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="Analisi, report e cancellazione duplicati"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            Background="{StaticResource BrushSurfaceSoft}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8" Margin="20,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Stato generale"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="550"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Input e operazioni" Style="{StaticResource SectionTitleStyle}" />

                            <TextBlock Text="Cartella foto" Style="{StaticResource CaptionTextStyle}" />
                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right"
                                        Width="100"
                                        Margin="10,0,0,0"
                                        Content="Sfoglia..."
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding BrowseFotoPathCommand}" />
                                <TextBox Margin="0"
                                         Text="{Binding FotoPath, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <TextBlock Text="Database SQLite" Style="{StaticResource CaptionTextStyle}" />
                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right"
                                        Width="100"
                                        Margin="10,0,0,0"
                                        Content="Sfoglia..."
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding BrowseDatabasePathCommand}" />
                                <TextBox Margin="0"
                                         Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <CheckBox Content="Mostra dettagli duplicati"
                                      IsChecked="{Binding VerboseDuplicates}" />

                            <TextBlock Text="Azioni" Style="{StaticResource CaptionTextStyle}" />

                            <Button Content="Avvia analisi"
                                    Command="{Binding AnalyzeCommand}" />

                            <Button Content="Genera report duplicati"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ReportCommand}" />

                            <Button Content="Cancella duplicati"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding DeleteCommand}" />

                            <Separator Margin="0,8,0,12" />

                            <TextBlock Text="Ultimo report" Style="{StaticResource SectionTitleStyle}" />

                            <TextBlock Text="Gruppi duplicati trovati" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding LastDuplicateGroupsCount}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="File candidati alla cancellazione" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding LastFilesToDeleteCount}"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Analisi" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding AnalysisState.SummaryText}" Style="{StaticResource CaptionTextStyle}" />
                            <ProgressBar Value="{Binding AnalysisState.Percentage}" />
                            <TextBlock Text="{Binding AnalysisState.CurrentItem}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Report" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding ReportState.SummaryText}" Style="{StaticResource CaptionTextStyle}" />
                            <ProgressBar Value="{Binding ReportState.Percentage}" />
                            <TextBlock Text="{Binding ReportState.CurrentStep}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Cancellazione" Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding DeletionState.SummaryText}" Style="{StaticResource CaptionTextStyle}" />
                            <ProgressBar Value="{Binding DeletionState.Percentage}" />
                            <TextBlock Text="{Binding DeletionState.CurrentItem}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Log operativo"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,16,0" />
                        <Button Content="Pulisci log"
                                Width="110"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ClearLogCommand}" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding LogMessages}"
                             DisplayMemberPath="FullText" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>