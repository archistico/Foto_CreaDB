<Window x:Class="FotoCreaDB.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FotoCreaDB.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="FotoCreaDB"
        Height="850"
        Width="1450"
        MinHeight="750"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PathLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource BrushAccentSoft}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextSoft}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BrushBg}" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="420" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource CardBorderStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Vertical"
                                DockPanel.Dock="Left">
                        <TextBlock Text="FotoCreaDB"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Analisi, report e cancellazione duplicati"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            Background="{StaticResource BrushSurfaceSoft}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="20,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Stato generale"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Grid.RowSpan="3"
                    Style="{StaticResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Input e operazioni"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="Cartella foto"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Width="100"
                                    Margin="10,0,0,0"
                                    Content="Sfoglia..."
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseFotoPathCommand}" />
                            <TextBox Margin="0"
                                     Text="{Binding FotoPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Text="Database SQLite"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Width="100"
                                    Margin="10,0,0,0"
                                    Content="Sfoglia..."
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseDatabasePathCommand}" />
                            <TextBox Margin="0"
                                     Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <CheckBox Content="Mostra dettagli duplicati"
                                  IsChecked="{Binding VerboseDuplicates}" />

                        <TextBlock Text="Azioni"
                                   Style="{StaticResource CaptionTextStyle}" />

                        <Button Content="Avvia analisi"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AnalyzeCommand}" />

                        <Button Content="Genera report duplicati"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ReportCommand}" />

                        <Button Content="Cancella duplicati"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DeleteCommand}" />

                        <Separator Margin="0,8,0,12" />

                        <TextBlock Text="Ultimo report"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="Gruppi duplicati trovati"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Text="{Binding LastDuplicateGroupsCount}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="File candidati alla cancellazione"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Text="{Binding LastFilesToDeleteCount}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Spazio occupato dai duplicati"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <TextBlock Text="{Binding LastFilesToDeleteSizeFormatted}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Analisi"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding AnalysisState.SummaryText}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <ProgressBar Value="{Binding AnalysisState.Percentage}" />
                        <TextBlock Text="{Binding AnalysisState.CurrentItem}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Report"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding ReportState.SummaryText}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <ProgressBar Value="{Binding ReportState.Percentage}" />
                        <TextBlock Text="{Binding ReportState.CurrentStep}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Cancellazione"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding DeletionState.SummaryText}"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <ProgressBar Value="{Binding DeletionState.Percentage}" />
                        <TextBlock Text="{Binding DeletionState.CurrentItem}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Grid.Column="3"
                    Grid.ColumnSpan="3"
                    Style="{StaticResource CardBorderStyle}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <TextBlock Text="Log operativo"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,16,0" />
                        <Button Content="Pulisci log"
                                Width="110"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ClearLogCommand}" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding LogMessages}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:LogMessageViewModel}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding PrefixText}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />

                                    <Button Content="{Binding ClickablePath}"
                                            Style="{StaticResource PathLinkButtonStyle}"
                                            Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding ClickablePath}"
                                            Visibility="{Binding HasClickablePath, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button Content="Apri"
                                            Style="{StaticResource MiniActionButtonStyle}"
                                            Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding ClickablePath}"
                                            Visibility="{Binding HasClickablePath, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button Content="Mostra cartella"
                                            Style="{StaticResource MiniActionButtonStyle}"
                                            Command="{Binding DataContext.ShowPathInExplorerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding ClickablePath}"
                                            Visibility="{Binding HasClickablePath, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBlock Text="{Binding SuffixText}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>