// Esempio di configurazione per FotoCreaDB
// Puoi modificare le estensioni e le opzioni secondo le tue esigenze.
{
  "NomeDb": "foto.db",
  "ProgressEvery": 500,
  "LogDettagliato": true,
  "VerboseDuplicates": false,

  // Estensioni considerate processabili (override di AppConfig.EstensioniPermesse)
  "EstensioniPermesse": [
    "jpg", "jpeg", "png", "gif", "bmp", "psd", "webp", "heic", "heif", "tif", "tiff",
    "raw", "arw", "cr2", "nef", "nrw", "orf", "raf", "rw2",
    "mp4", "mov", "avi", "wmv"
  ],

  // Estensioni per cui tentare la lettura dei metadati (immagini e RAW comuni)
  "ImageExtensions": [
    "jpg", "jpeg", "png", "gif", "bmp", "psd", "tif", "tiff",
    "webp", "heic", "heif", "raw", "arw", "cr2", "crw", "nef", "nrw", "orf", "raf", "rw2",
    "rwl", "sr2", "dng", "pef", "kdc", "erf", "srf", "mef", "mrw"
  ]
}
